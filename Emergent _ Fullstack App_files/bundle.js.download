// Rule-based search engine for Vishnu's portfolio

const entries = [{
  id: 'about',
  type: 'topic',
  keywords: ['about', 'about me', 'who', 'story', 'background', 'vishnu', 'bio'],
  title: 'About Vishnu',
  summary: 'Builder since childhood. Designer turned developer turned systems thinker.'
}, {
  id: 'skills',
  type: 'topic',
  keywords: ['skills', 'stack', 'tools', 'tech', 'technology', 'languages'],
  title: 'Skills & Stack',
  summary: 'Python, React, ML, SQL, FastAPI, MongoDB, and a designer\'s eye.'
}, {
  id: 'projects',
  type: 'topic',
  keywords: ['projects', 'work', 'portfolio', 'builds', 'apps'],
  title: 'Projects',
  summary: 'Four shipped systems spanning health, education, vision, and sport.'
}, {
  id: 'ai',
  type: 'topic',
  keywords: ['ai', 'ai work', 'machine learning', 'ml', 'models', 'artificial intelligence'],
  title: 'AI & ML Work',
  summary: 'Applied ML in production: OCR, face recognition, classical models.'
}, {
  id: 'experience',
  type: 'topic',
  keywords: ['experience', 'journey', 'timeline', 'growth', 'career'],
  title: 'Growth Timeline',
  summary: 'From first Python line in 2018 to startup building in 2025.'
}, {
  id: 'contact',
  type: 'topic',
  keywords: ['contact', 'email', 'reach', 'hire', 'linkedin', 'github'],
  title: 'Contact',
  summary: 'Email, LinkedIn, GitHub, and X.'
}, {
  id: 'challenges',
  type: 'topic',
  keywords: ['challenges', 'problems', 'solved', 'problem solving'],
  title: 'Problems Solved',
  summary: 'Problem → Action → Outcome, the way engineering should be framed.'
}];

// Add project entries
_mock__WEBPACK_IMPORTED_MODULE_0__.projects.forEach(p => {
  entries.push({
    id: p.slug,
    type: 'project',
    keywords: [p.slug, p.title.toLowerCase(), ...p.title.toLowerCase().split(' ')],
    title: p.title,
    summary: p.tagline,
    project: p
  });
});

// Add skill entries
_mock__WEBPACK_IMPORTED_MODULE_0__.skills.forEach(s => {
  entries.push({
    id: `skill-${s.name.toLowerCase()}`,
    type: 'skill',
    keywords: [s.name.toLowerCase()],
    title: s.name,
    summary: s.desc,
    skill: s
  });
});
function suggest(query, limit = 6) {
  const q = query.trim().toLowerCase();
  if (!q) return [];
  const scored = entries.map(e => {
    let score = 0;
    for (const k of e.keywords) {
      if (k === q) score += 100;else if (k.startsWith(q)) score += 40;else if (k.includes(q)) score += 20;
    }
    if (e.title.toLowerCase().includes(q)) score += 10;
    return {
      ...e,
      _score: score
    };
  }).filter(e => e._score > 0).sort((a, b) => b._score - a._score).slice(0, limit);
  return scored;
}
function resolve(query) {
  const s = suggest(query, 1);
  return s[0] || null;
