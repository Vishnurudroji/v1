body {
  margin: 0;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: #07090d;
  color: #e7eaef;
}

code, .mono {
  font-family: 'JetBrains Mono', Menlo, monospace;
}

.serif {
  font-family: 'Instrument Serif', Georgia, serif;
}

/* Selection */
::selection { background: rgba(45, 212, 191, 0.28); color: #e7fffa; }

/* Scrollbar */
::-webkit-scrollbar { width: 10px; height: 10px; }
::-webkit-scrollbar-track { background: #07090d; }
::-webkit-scrollbar-thumb { background: #1a2330; border-radius: 8px; }
::-webkit-scrollbar-thumb:hover { background: #263349; }

/* Grain overlay */
.grain::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  opacity: 0.035;
  z-index: 100;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='160' height='160'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
}

.glass {
  background: rgba(12, 16, 22, 0.55);
  backdrop-filter: blur(14px) saturate(140%);
  -webkit-backdrop-filter: blur(14px) saturate(140%);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.glass-strong {
  background: rgba(10, 14, 20, 0.78);
  backdrop-filter: blur(22px) saturate(150%);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  border: 1px solid rgba(94, 234, 212, 0.08);
}

.teal-glow {
  box-shadow: 0 0 0 1px rgba(94, 234, 212, 0.18), 0 20px 60px -20px rgba(45, 212, 191, 0.22);
}

.hairline { border-color: rgba(255,255,255,0.06); }

.blink { animation: blink 1.05s steps(1) infinite; }
@keyframes blink { 50% { opacity: 0; } }

.dot-pulse { animation: dotPulse 1.4s infinite ease-in-out both; }
@keyframes dotPulse { 0%,80%,100% { opacity: 0.25; } 40% { opacity: 1; } }

.fade-up { animation: fadeUp 600ms cubic-bezier(.2,.7,.2,1) both; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }

.marquee-track { animation: marquee 40s linear infinite; }
@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* Highlighted search match */
.match { color: #5eead4; background: rgba(94,234,212,0.08); padding: 0 2px; border-radius: 3px; }

/* Noise button hover ring */
.btn-ring { transition: box-shadow .25s ease, transform .25s ease, background-color .25s ease; }
.btn-ring:hover { box-shadow: 0 0 0 3px rgba(94,234,212,0.12); }
.btn-ring:active { transform: translateY(1px); }

/* Kbd */
.kbd { display:inline-flex; align-items:center; justify-content:center; min-width:1.5rem; height:1.5rem; padding:0 .4rem; border-radius:6px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); font-family:'JetBrains Mono',monospace; font-size:.72rem; color:#cfd6df; }
