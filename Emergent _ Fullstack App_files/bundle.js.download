// Mock data for Vishnu's portfolio - pure frontend, no backend

const personal = {
  name: 'Vishnu',
  handle: 'vishnu.dev',
  role: 'Developer · Systems Builder · AI Tinkerer',
  identity: "I've been building systems since childhood—today, I build them with code, data, and AI.",
  location: 'Sircilla, India',
  email: 'vishnu.builds@proton.me',
  github: 'https://github.com/vishnu-builds',
  linkedin: 'https://linkedin.com/in/vishnu-builds',
  x: 'https://x.com/vishnu_builds',
  availability: 'Open to startup & engineering roles'
};
const about = {
  intro: 'I grew up in Sircilla, a small town in Telangana. As a kid I was obsessed with building—blocks became bridges, bridges became miniature cities. That instinct to construct never left.',
  chapters: [{
    title: 'Childhood in Sircilla',
    body: 'Wooden blocks, LEGO, cardboard skylines. I would tear apart remote controls just to see the circuitry. Curiosity was the default setting.'
  }, {
    title: 'Pencil art & chess',
    body: 'Spent years on graphite portraits and still-life studies. Competed in district-level chess tournaments—podium finishes taught me patience and pattern recognition.'
  }, {
    title: 'The radium shop years',
    body: 'Worked part-time at a local radium/flex printing shop. Designed logos, flex banners, visiting cards in CorelDRAW and Photoshop. Learned typography, kerning, and what clients actually want.'
  }, {
    title: 'Transition to software',
    body: 'Picked up Python during college, fell hard for data structures, then ML. Design eye + engineering brain turned out to be a rare pairing.'
  }, {
    title: 'What I build now',
    body: 'Full systems from scratch—auth, APIs, ML pipelines, clean UIs. The goal is a startup of my own: a product that solves a real, stubborn problem.'
  }]
};
const skills = [{
