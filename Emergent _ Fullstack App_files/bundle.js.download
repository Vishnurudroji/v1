___CSS_LOADER_EXPORT___.push([module.id, `/* App-level custom utilities only. Do not center-align the container. */
.App { min-height: 100vh; position: relative; }

.section-pad { padding: 6rem 1.5rem; }
@media (min-width: 1024px) { .section-pad { padding: 8rem 3rem; } }

.container-xl { max-width: 1280px; margin: 0 auto; }

.h-display { font-family: 'Instrument Serif', serif; font-weight: 400; letter-spacing: -0.02em; }

.eyebrow { font-family: 'JetBrains Mono', monospace; font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: #5eead4; }

.card-dark { background: #0b0f15; border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; }
.card-dark:hover { border-color: rgba(94,234,212,0.18); }

.link-underline { position: relative; }
.link-underline::after { content:''; position:absolute; left:0; right:0; bottom:-2px; height:1px; background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform .3s ease; }
.link-underline:hover::after { transform: scaleX(1); }
`, "",{"version":3,"sources":["webpack://./src/App.css"],"names":[],"mappings":"AAAA,wEAAwE;AACxE,OAAO,iBAAiB,EAAE,kBAAkB,EAAE;;AAE9C,eAAe,oBAAoB,EAAE;AACrC,6BAA6B,eAAe,kBAAkB,EAAE,EAAE;;AAElE,gBAAgB,iBAAiB,EAAE,cAAc,EAAE;;AAEnD,aAAa,sCAAsC,EAAE,gBAAgB,EAAE,uBAAuB,EAAE;;AAEhG,WAAW,wCAAwC,EAAE,iBAAiB,EAAE,qBAAqB,EAAE,yBAAyB,EAAE,cAAc,EAAE;;AAE1I,aAAa,mBAAmB,EAAE,wCAAwC,EAAE,mBAAmB,EAAE;AACjG,mBAAmB,mCAAmC,EAAE;;AAExD,kBAAkB,kBAAkB,EAAE;AACtC,yBAAyB,UAAU,EAAE,iBAAiB,EAAE,MAAM,EAAE,OAAO,EAAE,WAAW,EAAE,UAAU,EAAE,wBAAwB,EAAE,oBAAoB,EAAE,sBAAsB,EAAE,8BAA8B,EAAE;AAC1M,+BAA+B,oBAAoB,EAAE","sourcesContent":["/* App-level custom utilities only. Do not center-align the container. */\n.App { min-height: 100vh; position: relative; }\n\n.section-pad { padding: 6rem 1.5rem; }\n@media (min-width: 1024px) { .section-pad { padding: 8rem 3rem; } }\n\n.container-xl { max-width: 1280px; margin: 0 auto; }\n\n.h-display { font-family: 'Instrument Serif', serif; font-weight: 400; letter-spacing: -0.02em; }\n\n.eyebrow { font-family: 'JetBrains Mono', monospace; font-size: .72rem; letter-spacing: .22em; text-transform: uppercase; color: #5eead4; }\n\n.card-dark { background: #0b0f15; border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; }\n.card-dark:hover { border-color: rgba(94,234,212,0.18); }\n\n.link-underline { position: relative; }\n.link-underline::after { content:''; position:absolute; left:0; right:0; bottom:-2px; height:1px; background: currentColor; transform: scaleX(0); transform-origin: left; transition: transform .3s ease; }\n.link-underline:hover::after { transform: scaleX(1); }\n"],"sourceRoot":""}]);
