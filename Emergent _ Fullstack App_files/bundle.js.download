const projects = [{
  slug: 'vitacare-ai',
  title: 'VitaCare AI',
  tagline: 'Personalized health companion powered by ML.',
  why: 'Rural patients I met through family struggled to interpret basic reports. I wanted a tool that speaks their language.',
  what: ['Parses uploaded medical reports (PDF/image)', 'Explains abnormal values in plain English', 'Tracks vitals over time with trend lines', 'Suggests when to consult a specialist'],
  stack: ['Python', 'FastAPI', 'React', 'MongoDB', 'scikit-learn', 'Tesseract OCR'],
  challenges: ['OCR accuracy on low-quality phone photos', 'Medical vocabulary ambiguity', 'Secure storage of sensitive records'],
  outcome: 'Beta tested with 40 users; 87% said they understood their reports for the first time.',
  insight: 'Empathy is a design requirement, not a feature.',
  color: '#22d3ee',
  accent: 'from-cyan-400/20 to-teal-500/10'
}, {
  slug: 'attendance-tracker',
