      z0 = src0[srcOffset0 + 2],
      w0 = src0[srcOffset0 + 3];
    let x1 = src1[srcOffset1 + 0],
      y1 = src1[srcOffset1 + 1],
      z1 = src1[srcOffset1 + 2],
      w1 = src1[srcOffset1 + 3];
